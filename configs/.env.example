# slurmDB connection settings used by the storage layer.
DB_HOST=""
DB_USER=""
DB_PASSWD=""
DB_DATABASE=""

# Compatible defaults for older MySQL/MariaDB servers.
DB_CHARSET="utf8mb4"
DB_COLLATION="utf8mb4_general_ci"

# Token required to open the admin web panel.
ADMIN_PANEL_TOKEN=""

# Token sent to mserver in the API_TOKEN header.
TASKSHIFT_MSERVER_API_TOKEN=""
